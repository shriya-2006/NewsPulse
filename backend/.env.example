APP_NAME=NewsPulse API
APP_ENV=development

FRONTEND_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=newspulse

SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REMEMBER_ME_EXPIRE_MINUTES=10080

# --- Outbound email (forgot-password) ---
# Leave SMTP_HOST blank to skip real email and log reset links to the
# console instead (fine for local dev). Example values for Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your.address@gmail.com
#   SMTP_PASSWORD=your-16-character-app-password   (NOT your normal password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@newspulse.local
SMTP_FROM_NAME=NewsPulse

# --- News providers ---
# Both optional — if left blank, search still works via the Google News
# RSS fallback (no key required). Fill these in for better results and
# more complete article data.
#   GNews:      https://gnews.io/          (free tier: 100 requests/day)
#   NewsData.io: https://newsdata.io/       (free tier: 200 requests/day)
GNEWS_API_KEY=
NEWSDATA_API_KEY=

# --- Report generation ---
# Where generated PDFs are stored. A relative path is resolved against
# the backend/ folder; created automatically if it doesn't exist.
REPORTS_DIR=generated_reports

# --- Search result caching ---
# How many hours a cached search stays fresh enough to serve without
# calling a live news provider again.
SEARCH_CACHE_FRESHNESS_HOURS=3

# --- Article retention (cleanup cron) ---
# Cached articles/searches older than this many days are deleted by
# app/scripts/cleanup_old_articles.py — see backend/README.md's
# "Cleanup (the retention cron)" section for how to schedule it.
ARTICLE_RETENTION_DAYS=90
